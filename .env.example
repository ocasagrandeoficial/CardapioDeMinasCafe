# Copie este arquivo para `.env` e ajuste os valores.

# Banco de dados PostgreSQL (Neon, Vercel Postgres, Supabase, etc.)
# Local / migrations: use a conexão DIRETA (sem "-pooler").
# Vercel (runtime serverless): use a conexão POOLED (com "-pooler").
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth / Auth.js — gere com: npx auth secret
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# Credenciais do administrador (login do painel /admin)
ADMIN_EMAIL="admin@deminascafe.com"
ADMIN_PASSWORD="uma-senha-forte"
